theorem lemma4_xor_pattern_language_preservation_of_mapped_branch_models
    {Place : Type u}
    {Trans : Type v}
    {Activity : Type w}
    [DecidableEq Place]
    {net : WorkflowNet Place Trans}
    {partition : Partition Trans}
